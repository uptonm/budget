# Prisma / Neon Postgres
# Locally use the direct (non-pooled) Neon connection string; Vercel uses the
# pooled one (host contains "-pooler").
DB_URL=""

# UploadThing (v7 token)
UPLOADTHING_TOKEN=""

# Clerk (shared production instance across *.uptonm.dev)
# Pull with: clerk env pull --instance <prod|dev instance id>
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/signin"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/signin"
# Production only on Vercel for the fleet gate; omit locally / preview
GATES_ORG_ID=""
GATES_APP_ID="budget"
